        "import pandas as pd\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "data = {\n",
        "\"Hours\":[1,2,3,4,5],\n",
        "\"Marks\":[40,50,60,70,85]\n",
        "}\n",
        "\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "print(df.head())\n",
        "print(df.info())\n",
        "print(df.describe())\n",
        "\n",
        "sns.heatmap(df.corr(),annot=True)\n",
        "plt.show()"
      ]
